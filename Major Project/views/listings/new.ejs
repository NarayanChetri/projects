<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust</title>
</head>
<body>
    <form action="/listings" method="post">
        <h3>Create a new listing</h3>
<input type="text" name="listing[title]" placeholder="enter title"><br>
<textarea name="listing[description]" placeholder="enter description" id=""></textarea><br>
<input name="listing[image]" placeholder="enter url/link"><br>
<input name="listing[price]" type="number" placeholder="enter price"><br>
<input type="text" name="listing[location]" placeholder="enter location" id="">
<button>Add</button>
    </form>
</body>
</html>