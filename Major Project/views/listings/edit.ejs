<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust</title>
</head>
<body>
    <form action="/listings/<%= listing._id%>?_method=PUT" method="post">
        <h3>Edit listing</h3>
<input type="text" name="listing[title]" value="<%=listing.title%>"><br>
<textarea name="listing[description]" value="<%=listing.description%> id=""></textarea><br>
<input name="listing[image]" value="<%=listing.image%>"><br>
<input name="listing[price]" type="number" value="<%=listing.price%>"><br>
<input type="text" name="listing[location]" value="<%=listing.location%>" id="">
<button>Edit</button>
    </form>
</body>
</html>